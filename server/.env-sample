CURSOR_API_KEY=cursor_api_key_here

# Optional: agent working directory (defaults to server cwd)
# AMELIA_AGENT_CWD=/home/you/WORKS/AMELIA/amelia-widget/server

# Persona: copy SOUL.sample.md → SOUL.md, USER.sample.md → USER.md
# AGENT_SOUL_PATH=/path/to/SOUL.md
# AGENT_USER_PATH=/path/to/USER.md

# Optional: agent state directory (auto-used on Node < 22.13 without node:sqlite)
# AMELIA_AGENT_STORE_DIR=/home/you/.amelia-agent-store

# Persisted Cursor agent session id (resume on restart; default under SDK state root)
# AMELIA_SESSION_DIR=/home/you/.amelia-agent-session

# AMELIA_MCP_ENABLED=0
# MCP_CONFIG_PATH=.cursor/mcp.json
# CURSOR_SDK_MCP_MODE=file
# Home Assistant HTTP MCP (optional; used in Docker or when set in mcp.json):
# HA_MCP_HTTP_URL=http://homeassistant.local:8123/api/mcp
# HA_API_ACCESS_TOKEN=your_long_lived_token
# HA_BASE_URL=http://homeassistant.local:8123

# WebSocket + HTTP (default http://127.0.0.1:8787)
# AMELIA_WS_HOST=127.0.0.1
# AMELIA_WS_PORT=8787

# Voice reply (local TTS: Piper preferred, else spd-say). Speaks short done line only.
# AMELIA_VOICE=1
# AMELIA_TTS=piper
# AMELIA_PIPER_MODEL=/home/you/.local/share/piper/en_US-kristin-medium.onnx
# AMELIA_VOICE_MAX_CHARS=320
# AMELIA_PIPER_LENGTH_SCALE=0.94
# AMELIA_PIPER_SENTENCE_SILENCE=0
# AMELIA_PIPER_WAV=0
# AMELIA_PIPER_NOISE_SCALE=0.55
# AMELIA_SPD_RATE=-15
# spd-say fallback voices: `spd-say -l en-US -L`
# AMELIA_SPD_LANGUAGE=en-US
# AMELIA_SPD_VOICE=Andrea

# Debug: log conversations to stderr and .amelia-conversations.ndjson
# AMELIA_DEBUG=1
# AMELIA_DEBUG_STREAM=1
# AMELIA_DEBUG_LOG=/path/to/conversations.ndjson
